# Copy this file to .env and fill in real values before running/deploying.

# Security - generate a random string for production, e.g. `openssl rand -hex 32`
SECRET_KEY=change-this-secret-key-in-production

# Bootstrap admin account (created automatically on first startup if no admin exists)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_NAME=Thamarai Selvan S

# Database (SQLite by default; use a Postgres URL on Render for persistence, e.g.
# postgresql://user:password@host:5432/dbname)
DATABASE_URL=sqlite:///./mlsa.db

# Email - if thamaraiselvan@studentambassadors.com is a real inbox you control, use it here with
# its App Password (Google Workspace/Gmail-hosted addresses support App Passwords the same way).
# If it's not an inbox you can send from (e.g. it's just a listed contact address), use a Gmail
# account you do control instead and keep this as the FROM_NAME / reply-to identity.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=thamaraiselvan@studentambassadors.com
SMTP_PASSWORD=your-16-char-app-password
FROM_NAME=MLSA - Saranathan College of Engineering (AI & DS)

# CORS - comma-separated list of frontend URLs allowed to call this API
FRONTEND_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
